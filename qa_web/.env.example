# AI API 配置（必填）
API_KEY=your_api_key_here

# 可选配置
ANTHROPIC_BASE_URL=https://api.jiekou.ai/anthropic
AI_MODEL=claude-sonnet-4-5-20250929
PORT=8080

# Tavily 搜索配置（可选）
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_ENABLED=false              # true 启用，false 禁用
TAVILY_MAX_RESULTS=3              # 每次返回的结果数（1-5）
TAVILY_SEARCH_DEPTH=basic         # basic 或 advanced
TAVILY_TIMEOUT=5                  # 超时时间（秒）
